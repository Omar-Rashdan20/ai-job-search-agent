# LLM - Ollama
# 1. Install Ollama: https://ollama.com
# 2. Pull a model:  ollama pull qwen2.5:1.5b
# 3. Copy these LLM settings into .env to use Ollama instead of Gemini.

LLM_PROVIDER=ollama
OLLAMA_API_BASE=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b
LLM_TEMPERATURE=0
LLM_FALLBACK_TO_OLLAMA=false

TAVILY_API_KEY=tvly-...
SEARCH_SCORE_THRESHOLD=0.10
DEFAULT_TOP_RESULTS=5
DEFAULT_LANGUAGE=English
DEFAULT_COUNTRY=Jordan
DEFAULT_JOB_TITLE=AI Engineer
DEFAULT_WEBSITES=linkedin.com,bayt.com,akhtaboot.com,tanqeeb.com

SCRAPEGRAPH_API_KEY=sgai-...
MAX_SCRAPE_URLS=3
SCRAPE_TIMEOUT_SECONDS=10

AGENTOPS_API_KEY=
OUTPUT_DIR=./output
