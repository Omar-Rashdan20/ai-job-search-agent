# LLM - Gemini
LLM_PROVIDER=gemini
LLM_API_BASE=
LLM_MODEL=gemini/gemini-2.5-flash
GEMINI_API_KEY=your_gemini_api_key_here
LLM_TEMPERATURE=0
LLM_FALLBACK_TO_OLLAMA=true
OLLAMA_API_BASE=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b

# Search — https://tavily.com
TAVILY_API_KEY=tvly-...
SEARCH_SCORE_THRESHOLD=0.10
DEFAULT_TOP_RESULTS=5
DEFAULT_LANGUAGE=English
DEFAULT_COUNTRY=Jordan
DEFAULT_JOB_TITLE=AI Engineer
DEFAULT_WEBSITES=linkedin.com,bayt.com,akhtaboot.com,tanqeeb.com

# Scraping — https://scrapegraph.ai
SCRAPEGRAPH_API_KEY=sgai-...
MAX_SCRAPE_URLS=3
SCRAPE_TIMEOUT_SECONDS=10

# Monitoring (optional) — https://app.agentops.ai
AGENTOPS_API_KEY=

# Output
OUTPUT_DIR=./output
